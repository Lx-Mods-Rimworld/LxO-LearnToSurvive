<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <JobDef>
    <defName>LTS_SmartHaul</defName>
    <driverClass>LearnToSurvive.JobDriver_SmartHaul</driverClass>
    <reportString>smart hauling.</reportString>
    <casualInterruptible>true</casualInterruptible>
    <collideWithPawns>false</collideWithPawns>
    <allowOpportunisticPrefix>true</allowOpportunisticPrefix>
  </JobDef>

  <JobDef>
    <defName>LTS_UnloadHauledItems</defName>
    <driverClass>LearnToSurvive.JobDriver_UnloadHauledItems</driverClass>
    <reportString>unloading hauled items.</reportString>
    <casualInterruptible>true</casualInterruptible>
    <collideWithPawns>false</collideWithPawns>
  </JobDef>

  <JobDef>
    <defName>LTS_WriteBook</defName>
    <driverClass>LearnToSurvive.JobDriver_WriteBook</driverClass>
    <reportString>writing a book.</reportString>
    <casualInterruptible>true</casualInterruptible>
  </JobDef>

  <JobDef>
    <defName>LTS_ReadBook</defName>
    <driverClass>LearnToSurvive.JobDriver_ReadBook</driverClass>
    <reportString>reading {A}.</reportString>
    <casualInterruptible>true</casualInterruptible>
    <joyKind>LTS_Reading</joyKind>
    <joyMaxParticipants>1</joyMaxParticipants>
    <joyGainRate>1</joyGainRate>
    <joyDuration>4000</joyDuration>
  </JobDef>

</Defs>
